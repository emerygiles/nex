# ---- Run mode ----
# sandbox = in-process mock MCP + bundled APT dataset (no Splunk needed)
# live    = real Splunk MCP Server
MODE=sandbox

# ---- Splunk MCP (live mode) ----
SPLUNK_MCP_URL=https://localhost:8089/services/mcp
SPLUNK_MCP_TOKEN=
SPLUNK_VERIFY_TLS=false

# ---- AI brain ----
# foundation_sec = Cisco Foundation-Sec-8B-Instruct (open weights) via local Ollama (OpenAI-compatible)
# anthropic      = dev-time fallback (needs ANTHROPIC_API_KEY)
# scripted       = deterministic, no model call (lets sandbox run with zero deps)
AI_PROVIDER=foundation_sec
FOUNDATION_BASE_URL=http://localhost:11434/v1
FOUNDATION_MODEL=hf.co/mradermacher/Foundation-Sec-8B-Instruct-GGUF:Q4_K_M
AI_SAFETY_NET=true
ANTHROPIC_API_KEY=

# ---- Production safety ----
# false = NEX PROPOSES the detection and waits for analyst approval (POST /deploy) — prod-safe DEFAULT.
# true  = NEX deploys the detection itself (hands-off demo: you see the gap close end-to-end).
# Either way, authored/deployed SPL is checked against a command allowlist (no delete/outputlookup/etc).
AUTO_DEPLOY=false

# ---- Visibility ----
# Threat profile that ranks the blind spots (priority queue). See backend/threat_profiles.py.
# default | ransomware | cloud_saas
THREAT_PROFILE=default

# ---- Server ----
HOST=127.0.0.1
PORT=8800
